                            except Exception as e: st.error(f"Error reading PDF: {e}")
                        else: document_text = uploaded_file.getvalue().decode("utf-8")

                        if document_text:
                            chunks = get_text_chunks(document_text)
                            st.session_state.doc_chunks = chunks
                            progress_bar, embeddings = st.progress(0), []
                            for i, chunk in enumerate(chunks):
                                embeddings.append(cortex_embed(chunk))
                                progress_bar.progress((i + 1) / len(chunks))
                            st.session_state.doc_embeddings = embeddings
                            status.update(label="Document Processed Successfully.", state="complete", expanded=False)
            elif st.session_state.doc_chunks:
                st.session_state.doc_chunks, st.session_state.doc_embeddings = [], []

    with col_right:
        st.markdown("#### Analysis & Matching")
        if not st.session_state.doc_chunks: st.info("Please upload a document to begin analysis.")
        else:
            with st.container(border=True):
                search_query = st.text_input("Ask a question about the document:")
                if st.button("Search Context", type="secondary") and search_query:
                    with st.spinner("Searching document vectors..."):
                        try:
                            query_embedding = cortex_embed(search_query)
                            similarities = sorted([(cosine_similarity(query_embedding, emb), chunk) for emb, chunk in zip(st.session_state.doc_embeddings, st.session_state.doc_chunks)], key=lambda x: x[0], reverse=True)
                            retrieved_context = "\n\n...[SNIP]...\n\n".join([item[1] for item in similarities[:3]])
                            rag_prompt = f"You are a helpful analyst. Answer the user's question using ONLY the retrieved document context below.\n--- RETRIEVED CONTEXT ---\n{retrieved_context}\n-------------------------\nQuestion: {search_query}"
                            response = cortex_complete("llama3.1-8b", rag_prompt)
                            st.success("Analysis Complete")
                            st.markdown(response)
                            with st.expander("View Retrieved Source"): st.caption(retrieved_context)
                        except Exception as e: st.error(f"RAG Search Failed: {e}")

            st.write("") 
            st.markdown("#### Intelligent Employee Matching")
            if st.button("Find Employees Matching Document Tech Stack", type="primary", use_container_width=True):
                with st.spinner("Extracting tech stack and matching profiles..."):
                    context = "\n\n".join(st.session_state.doc_chunks[:5])
                    extract_prompt = f"Extract ONLY the technology stack (languages, frameworks, tools, DBs, cloud) mentioned below. Return ONLY a comma-separated list. --- DOCUMENT ---\n{context}"
                    try:
                        raw_tech_csv = cortex_complete("llama3.1-8b", extract_prompt).replace('`', '').replace('*', '').replace('\n', '').strip()
                        st.info(f"**Detected Tech Stack:** `{raw_tech_csv}`")
                        tech_list = [t.strip().upper() for t in raw_tech_csv.split(",") if t.strip()]
                        
                        if tech_list:
                            placeholders = ", ".join("'" + t.replace("'", "''") + "'" for t in tech_list)
                            sql = f"""
                                WITH MatchedSkills AS (
                                    SELECT e.FIRST_NAME, e.LAST_NAME, e.DEPARTMENT, s.SKILL_TAG
                                    FROM {AN_DB}.{AN_SCHEMA}.DIM_EMPLOYEE e
                                    JOIN {PL_DB}.{PL_SCHEMA}.STG_SKILLS s ON e.EMPLOYEE_ID = s.EMPLOYEE_ID
                                    WHERE UPPER(s.SKILL_TAG) IN ({placeholders})
                                ),
                                EmployeeSkillCounts AS (
                                    SELECT FIRST_NAME, LAST_NAME, DEPARTMENT, COUNT(DISTINCT SKILL_TAG) AS MATCHED_SKILL_COUNT,
                                        LISTAGG(DISTINCT SKILL_TAG, ', ') WITHIN GROUP (ORDER BY SKILL_TAG) AS MATCHED_SKILLS
                                    FROM MatchedSkills GROUP BY FIRST_NAME, LAST_NAME, DEPARTMENT
                                )
                                SELECT RANK() OVER (ORDER BY MATCHED_SKILL_COUNT DESC) AS RANK, *
                                FROM EmployeeSkillCounts ORDER BY RANK ASC
                            """
                            df = session.sql(sql).to_pandas()
                            if not df.empty:
                                st.dataframe(df, use_container_width=True, hide_index=True)
                                st.session_state.last_df = df
                            else: st.warning("No employees found matching these specific skills.")
                        else: st.warning("No technical skills were detected in the document.")
                    except Exception as e: st.error(f"Error querying database: {e}")

