@st.cache_data(ttl=600)
def get_dynamic_schema():
    query = f"""
        SELECT TABLE_NAME, COLUMN_NAME, DATA_TYPE
        FROM {PL_DB}.INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = '{PL_SCHEMA}'
        ORDER BY TABLE_NAME, ORDINAL_POSITION
    """
    try:
        df = session.sql(query).to_pandas()
        t_map, t_types = {}, {}
        
        for table, group in df.groupby('TABLE_NAME'):
            t_map[table] = group['COLUMN_NAME'].tolist()
            type_dict = {}
            for _, row in group.iterrows():
                col, raw_type = row['COLUMN_NAME'], str(row['DATA_TYPE']).upper()
                if raw_type in ['TEXT', 'VARCHAR']: val_type = "STRING"
                elif raw_type in ['NUMBER', 'INTEGER', 'BIGINT']: val_type = "INTEGER"
                elif raw_type in ['FLOAT', 'DOUBLE', 'REAL']: val_type = "FLOAT"
                elif raw_type == 'BOOLEAN': val_type = "BOOLEAN"
                elif raw_type == 'DATE': val_type = "DATE"
                elif raw_type == 'ARRAY': val_type = "ARRAY"
                else: val_type = "STRING"
                type_dict[col] = val_type
            t_types[table] = type_dict
        return t_map, t_types
    except Exception as e:
        st.error(f"Failed to fetch schema metadata: {e}")
        return {}, {}

TABLE_MAP, TABLE_TYPES = get_dynamic_schema()

@st.cache_data(ttl=300)
def get_stage_files():
    try:
        rows = session.sql(f"LIST @{PL_FQN}.{PL_STAGE}").collect()
        files = {}
        for r in rows:
            name = str(r["name"]).split("/")[-1]
            tbl = name.replace(".csv", "").strip().upper()
            files[tbl] = {"name": name, "size": r["size"], "last_modified": str(r["last_modified"])}
        return files
    except Exception: return {}

def get_csv_header(file_name):
    try:
        df = session.read.option("SKIP_HEADER", 0).option("FIELD_OPTIONALLY_ENCLOSED_BY", '"').csv(f"@{PL_FQN}.{PL_STAGE}/{file_name}")
        rows = df.limit(1).collect()
        if rows: return [str(val).strip().upper() for val in rows[0] if val is not None and str(val).strip()]
    except Exception: pass
    return []

def get_full_csv_as_pandas(file_name, columns):
    if not columns: return pd.DataFrame()
    try:
        df_snowpark = session.read.option("SKIP_HEADER", 1).option("FIELD_OPTIONALLY_ENCLOSED_BY", '"').csv(f"@{PL_FQN}.{PL_STAGE}/{file_name}")
        pd_df = df_snowpark.limit(MAX_ROWS_EDITOR).to_pandas()
        num_cols = min(len(pd_df.columns), len(columns))
        pd_df = pd_df.iloc[:, :num_cols]
        pd_df.columns = columns[:num_cols]
        return pd_df
    except Exception: return pd.DataFrame()

def save_dataframe_to_stage(df, file_name):
    tmp_dir = tempfile.gettempdir()
    file_path = os.path.join(tmp_dir, file_name)
    df.to_csv(file_path, index=False, header=True)
    session.file.put(file_path, f"@{PL_FQN}.{PL_STAGE}", auto_compress=False, overwrite=True)
    get_stage_files.clear() 

def detect_schema_drift(table_name, csv_columns):
    expected = TABLE_MAP.get(table_name, [])
    expected_upper = [c.upper() for c in expected]
    csv_upper = [c.upper() for c in csv_columns]
    
    return {
        "expected": expected_upper,
        "csv_columns": csv_upper,
        "missing_in_csv": [c for c in expected_upper if c not in csv_upper],
        "extra_in_csv": [c for c in csv_upper if c not in expected_upper],
        "col_count_match": len(expected_upper) == len(csv_upper),
        "order_match": csv_upper == expected_upper,
        "has_drift": bool([c for c in expected_upper if c not in csv_upper] or [c for c in csv_upper if c not in expected_upper]),
    }

def _try_parse_date(val, fmt):
    try:
        datetime.strptime(val, fmt)
        return True
    except ValueError: return False

def validate_data(table_name, df_data):
    raw_issues, expected_types = [], TABLE_TYPES.get(table_name, {})
    if df_data.empty: return [], [{"severity": "ERROR", "message": "File is empty or has no data rows"}]

    col_mapping = {c: c for c in df_data.columns if c in expected_types}
    for idx, row in df_data.iterrows():
        for col_name in col_mapping:
            val = str(row[col_name]).strip() if pd.notna(row[col_name]) else ""
            dtype = expected_types.get(col_name, "STRING")
            if val == "" or val.upper() in ("NONE", "NULL", "NAN"): continue
            
            issue_found, sev, msg = False, "", ""
            if dtype == "DATE":
                if not any([_try_parse_date(val, fmt) for fmt in ["%Y-%m-%d", "%m/%d/%Y", "%d-%m-%Y", "%Y/%m/%d"]]):
                    issue_found, sev, msg = True, "WARNING", f"'{val}' may not parse as DATE"
            elif dtype in ("INTEGER", "NUMBER"):
                try: int(float(val))
                except ValueError: issue_found, sev, msg = True, "ERROR", f"'{val}' is not a valid integer"
            elif dtype == "FLOAT":
                try: float(val)
                except ValueError: issue_found, sev, msg = True, "ERROR", f"'{val}' is not a valid number"
            elif dtype == "BOOLEAN":
                if val.upper() not in ("TRUE", "FALSE", "1", "0", "YES", "NO", "T", "F"):
                    issue_found, sev, msg = True, "ERROR", f"'{val}' is not a valid boolean"
                    
            if issue_found:
                raw_issues.append({"row_idx": idx, "col_name": col_name, "severity": sev, "message": f"Column {col_name} (Row {idx+2}): {msg}"})

    seen, unique_issues = set(), []
    for i in raw_issues:
        base_msg = re.sub(r"\(Row \d+\):", "", i["message"]).strip()
        if base_msg not in seen:
            seen.add(base_msg)
            unique_issues.append(i)
    return raw_issues, unique_issues

def generate_cortex_healing_suggestions(table_name, drift_info, data_issues):
    if not drift_info["has_drift"] and not data_issues and drift_info["order_match"]: 
        return []
    
    # 1. Trim the payload size to the absolute minimum required context
    trimmed_drift = {
        "missing": drift_info.get("missing_in_csv", []),
        "extra": drift_info.get("extra_in_csv", [])
    }
    
    # Limit to top 3 issues and only send the core message string
    limited_issues = [i["message"] for i in data_issues[:3]] if data_issues else []
    
    # 2. Use [INST] tags and highly restrictive instructions to eliminate generation lag
    prompt = f"""
    [INST]
    You are a Snowflake Data Engineer. Fix this pipeline failure for `{PL_FQN}.{table_name}`.
    DRIFT: {json.dumps(trimmed_drift)}
    ERRORS: {json.dumps(limited_issues)}
    
    Output ONLY a valid JSON array. Do not include markdown tags, greetings, or explanations. Format exactly like this:
    [
      {{"type": "SQL", "description": "Short desc", "action": "ALTER TABLE ..."}},
      {{"type": "FILE_FIX", "description": "Short desc", "action": "Fix instructions"}}
    ]
    [/INST]
    """
    
    try:
        escaped_prompt = prompt.replace("'", "''")
        # Ensure we are hitting the fastest capable model available in Cortex
        cortex_query = f"SELECT SNOWFLAKE.CORTEX.COMPLETE('llama3.1-8b', '{escaped_prompt}') AS LLM_RESPONSE"
        
        llm_result = session.sql(cortex_query).collect()[0]["LLM_RESPONSE"]
        
        clean_json_str = re.sub(r"```json\s*", "", llm_result)
        clean_json_str = re.sub(r"```\s*", "", clean_json_str).strip()
        
        return json.loads(clean_json_str)
    except Exception as e:
        return [{"type": "WARNING", "description": "LLM Analysis failed.", "action": str(e)}]

def load_file(table_name, file_name, on_error="CONTINUE"):
    try:
        result = session.sql(f"""
            COPY INTO {PL_FQN}.{table_name}
            FROM @{PL_FQN}.{PL_STAGE}/{file_name}
            FILE_FORMAT = (TYPE='CSV' SKIP_HEADER=1 FIELD_OPTIONALLY_ENCLOSED_BY='"' NULL_IF=('', 'NULL', 'null') ERROR_ON_COLUMN_COUNT_MISMATCH=FALSE)
            ON_ERROR = '{on_error}' PURGE = FALSE
        """).collect()
        if result: return {"status": "SUCCESS", "rows_loaded": result[0]["rows_loaded"], "errors_seen": result[0]["errors_seen"], "first_error": str(result[0]["first_error"])}
    except Exception as e: return {"status": "FAILED", "error": str(e)}


