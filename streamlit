@st.cache_data(show_spinner=False)
def cortex_embed(text: str) -> list:
    return list(session.sql("SELECT SNOWFLAKE.CORTEX.EMBED_TEXT_768('e5-base-v2', ?)", params=[text]).collect()[0][0])

def cortex_complete(model: str, prompt: str) -> str:
    return session.sql("SELECT SNOWFLAKE.CORTEX.COMPLETE(?, ?)", params=[model, prompt]).collect()[0][0]

def call_cortex_analyst(history: list):
    response = _snowflake.send_snow_api_request(
        "POST", "/api/v2/cortex/analyst/message", {}, {},
        {"messages": history, "semantic_model_file": SEMANTIC_MODEL_FILE}, {}, 30000,
    )
    status, raw = response.get("status", 200), response.get("content", "{}")
    if isinstance(raw, str):
        try: raw = json.loads(raw)
        except Exception: return [], f"Could not parse API response: {raw[:200]}"
    if status >= 400: return [], f"(Code {raw.get('code', status)}) {raw.get('message', 'Unknown error.')}"
    return raw.get("message", {}).get("content", []), None

def get_text_chunks(text: str, chunk_size: int = 1000, overlap: int = 200) -> list:
    chunks, start = [], 0
    while start < len(text):
        chunks.append(text[start : start + chunk_size])
        start += chunk_size - overlap
    return chunks

def cosine_similarity(v1: list, v2: list) -> float:
    dot, mag = sum(a * b for a, b in zip(v1, v2)), (sum(a ** 2 for a in v1) ** 0.5) * (sum(b ** 2 for b in v2) ** 0.5)
    return dot / mag if mag else 0.0

def safe_text(text: str) -> str: return text.encode("utf-8", "ignore").decode("utf-8")


